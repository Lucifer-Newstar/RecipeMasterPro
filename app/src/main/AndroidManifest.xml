<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.recipemasterpro">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RecipeMasterPro">

        <!-- Firebase Messaging Service - ONLY ONE DECLARATION -->
        <service
            android:name=".services.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Splash Activity -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.RecipeMasterPro">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth Activities -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".activities.MainActivity"
            android:exported="false" />
        <activity
            android:name=".activities.UserMigrationActivity"
            android:exported="false" />

        <!-- Recipe Activities -->
        <activity
            android:name=".activities.AddRecipeActivity"
            android:exported="false" />
        <activity
            android:name=".activities.RecipeListActivity"
            android:exported="false" />
        <activity
            android:name=".activities.MyRecipesActivity"
            android:exported="false" />
        <activity
            android:name=".activities.RecipeDetailActivity"
            android:exported="false" />
        <activity
            android:name=".activities.EditRecipeActivity"
            android:exported="false" />

        <!-- Video Activities -->
        <activity
            android:name=".activities.VideoPlayerActivity"
            android:configChanges="orientation|screenSize"
            android:exported="false" />
        <activity
            android:name=".activities.ReelsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ChefReelsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ReelPlayerActivity"
            android:configChanges="orientation|screenSize"
            android:exported="false" />

        <!-- Search & Profile -->
        <activity
            android:name=".activities.SearchActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />
        <activity
            android:name=".activities.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".activities.EditProfileActivity"
            android:exported="false" />
        <activity
            android:name=".activities.NotificationActivity"
            android:exported="false" />
        <activity
            android:name=".activities.admin.AdminActivity"
            android:exported="false" />

    </application>

</manifest>