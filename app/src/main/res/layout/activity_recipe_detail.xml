<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Recipe Image -->
        <ImageView
            android:id="@+id/recipeImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Recipe Image"/>

        <!-- Content Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title and Chef -->
            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recipe Title"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/chefText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="By Chef Name"
                android:textSize="14sp"
                android:textColor="@color/secondary"
                android:layout_marginBottom="16dp"/>

            <!-- Rating Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <RatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="0.5"
                    android:isIndicator="true"
                    style="?android:attr/ratingBarStyleSmall"/>

                <TextView
                    android:id="@+id/ratingCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(0 ratings)"
                    android:textSize="12sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/descriptionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recipe description goes here..."
                android:textSize="14sp"
                android:textColor="@android:color/black"
                android:layout_marginBottom="16dp"/>

            <!-- Time and Servings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/timeText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Prep: 15 min | Cook: 30 min"
                    android:textSize="14sp"
                    android:textColor="@color/accent"/>

                <TextView
                    android:id="@+id/servingsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Serves: 4"
                    android:textSize="14sp"
                    android:textColor="@color/accent"/>
            </LinearLayout>

            <!-- Ingredients Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingredients"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/noIngredientsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No ingredients added yet"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/ingredientsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone"/>

            <!-- Steps Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instructions"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/noStepsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No steps added yet"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/stepsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone"/>

            <!-- Ratings and Reviews Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ratings and Reviews"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/ratingsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"/>

            <!-- Comments Section - Improved Styling -->
            <LinearLayout
                android:id="@+id/commentsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:background="@drawable/border_gray"
                android:visibility="visible">

                <TextView
                    android:id="@+id/commentCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comments (0)"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="12dp"/>

                <!-- Add Comment -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <EditText
                        android:id="@+id/commentInput"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:hint="Write a comment..."
                        android:textSize="14sp"
                        android:background="@drawable/border_gray"
                        android:padding="8dp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/postCommentButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Post"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/primary"
                        android:textColor="@android:color/white"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"/>
                </LinearLayout>

                <!-- No Comments Message -->
                <TextView
                    android:id="@+id/noCommentsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No comments yet. Be the first to comment!"
                    android:textSize="14sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_marginBottom="16dp"
                    android:layout_gravity="center"
                    android:visibility="gone"/>

                <!-- Comments List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/commentsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="visible"/>

            </LinearLayout>

            <!-- CHEF BUTTONS (Edit, Delete, Stats) -->
            <LinearLayout
                android:id="@+id/chefButtonLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/editButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✏️ Edit"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/secondary"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/deleteButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🗑️ Delete"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/error"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/statsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📊 Stats"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/accent"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- USER BUTTONS (Rate, Like, Favorite, Share, Report) -->
            <LinearLayout
                android:id="@+id/userButtonLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/rateButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⭐ Rate"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/secondary"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/likeButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="❤️ Like"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/error"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/favoriteButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔖 Save"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/accent"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/shareButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📤 Share"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/primary"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/reportButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🚩 Report"
                    android:textAllCaps="false"
                    android:backgroundTint="@android:color/darker_gray"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="50dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
